# Cloud Service Configuration
# Copy this file to .env and fill in your actual credentials
# NEVER commit .env to Git!

# AWS Configuration
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name

# Azure Configuration
AZURE_STORAGE_ACCOUNT_NAME=your_storage_account_name
AZURE_STORAGE_ACCOUNT_KEY=your_storage_account_key
AZURE_CONTAINER_NAME=your-container-name

# Google Cloud Configuration
GCP_PROJECT_ID=your_gcp_project_id
GCP_PRIVATE_KEY_ID=your_private_key_id
GCP_PRIVATE_KEY=your_private_key_here
GCP_CLIENT_EMAIL=your_service_account_email
GCP_STORAGE_BUCKET=your-gcs-bucket

# Alibaba Cloud Configuration
ALIYUN_ACCESS_KEY_ID=your_aliyun_access_key
ALIYUN_ACCESS_KEY_SECRET=your_aliyun_secret
ALIYUN_OSS_BUCKET=your-oss-bucket
ALIYUN_REGION=cn-hangzhou
